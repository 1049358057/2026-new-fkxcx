@import "./styles/glassmorphism.wxss";

page {
  background-color: var(--glass-bg-color);
  background-image: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.Pop-ups {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 1000;
    opacity: 0;
    outline: 0;
    text-align: center;
    transform: scale(1.185);
    backface-visibility: hidden;
    perspective: 2000rpx;
    background: rgba(0, 0, 0, 0.4);
    transition: all 0.3s ease-in-out 0s;
    pointer-events: none;
    backdrop-filter: blur(5rpx);
    -webkit-backdrop-filter: blur(5rpx);
}

.Pop-ups::before {
    content: "\200B";
    display: inline-block;
    height: 100%;
    vertical-align: middle;
}

.show {
    opacity: 1;
    transition-duration: 0.3s;
    transform: scale(1);
    overflow-x: hidden;
    overflow-y: auto;
    pointer-events: auto;
}

.Pop-ups .dialog {
    position: relative;
    display: inline-block;
    vertical-align: middle;
    margin-left: auto;
    margin-right: auto;
    width: 680rpx;
    max-width: 100%;
    background: var(--glass-card-bg);
    border-radius: 16rpx;
    overflow: hidden;
    box-shadow: 0 8rpx 32rpx 0 var(--glass-shadow);
    backdrop-filter: blur(10rpx);
    -webkit-backdrop-filter: blur(10rpx);
    border: 1px solid var(--glass-border);
    animation: fadeIn 0.3s ease forwards;
}

.Pop-ups .bar {
    display: flex;
    position: relative;
    align-items: center;
    min-height: 100rpx;
    justify-content: space-between;
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--glass-text-color);
    border-bottom: 1px solid var(--glass-border);
}

.Pop-ups .content {
    position: absolute;
    text-align: center;
    width: calc(100% - 340rpx);
    left: 0;
    right: 0;
    bottom: 0;
    top: 0;
    margin: auto;
    height: 60rpx;
    font-size: 32rpx;
    line-height: 60rpx;
    cursor: none;
    pointer-events: none;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
    color: var(--glass-text-color);
    font-weight: 500;
}

.Pop-ups .action {
    display: flex;
    align-items: center;
    height: 100rpx;
    justify-content: center;
    max-width: 100%;
    flex: 1;
    background-color: transparent;
    border: none;
    color: var(--glass-text-color);
    font-weight: 500;
}

.progress {
    overflow: hidden;
    height: 20rpx;
    background: rgba(255, 255, 255, 0.15);
    display: inline-flex;
    align-items: center;
    width: 100%;
    border-radius: 10rpx;
    box-shadow: inset 0 2rpx 4rpx rgba(31, 38, 135, 0.1);
}

.progress view {
    width: 0;
    height: 100%;
    align-items: center;
    display: flex;
    justify-items: flex-end;
    justify-content: space-around;
    font-size: 20rpx;
    color: #fff;
    transition: width 0.6s ease;
    background: linear-gradient(90deg, var(--glass-gradient-start), var(--glass-gradient-end));
    border-radius: 10rpx;
}