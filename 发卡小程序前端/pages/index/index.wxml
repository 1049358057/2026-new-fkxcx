<view class="glass-container">
  <view class="glass-box glass-fade-in">
    <!-- 搜索框移到顶部 -->
    <view class="search-container">
      <input class="glass-input search-input" placeholder="搜索分类..." bindinput="onSearchInput" value="{{searchKeyword}}" />
      <view class="search-icon">🔍</view>
    </view>
    
    <!-- 卡片式商品展示 -->
    <view class="product-grid">
      <block wx:for="{{classArray}}" wx:key="cid" wx:for-index="idx">
        <view class="product-card" 
              bindtap="onProductTap" 
              data-index="{{idx}}" 
              data-cid="{{item.cid}}"
              data-name="{{item.name}}"
              hover-class="product-card-hover">
          <view class="product-image" catchtap="onProductTap" data-index="{{idx}}">
            <image src="{{item.image || '../../images/km.png'}}" mode="aspectFill"></image>
          </view>
          <view class="product-info" catchtap="onProductTap" data-index="{{idx}}">
            <view class="product-name">{{item.name}}</view>
            <view class="product-desc">{{item.video_times == 0 ? '直接领取' : '观看视频领取'}}</view>
          </view>
        </view>
        
        <!-- 每两行(4个商品)后插入广告 -->
        <block wx:if="{{(idx + 1) % 4 === 0}}">
          <view class="ad-card">
            <ad unit-id="adunit-f92b132d9fffeb2d" ad-type="grid" grid-opacity="0.8"></ad>
          </view>
        </block>
      </block>
    </view>
  </view>
</view>

<view class="Pop-ups {{shareShow?'show':''}} ">
    <view class="dialog">
        <view class="bar">
            <view class="content">分享提示</view>
        </view>
    <view class="glass-text" style="padding:50rpx;">
              {{data.shareTip!=''?data.shareTip:'还需分享一次好友或群即可领取卡密了'}}
            </view>
        <view class="bar">
      <button bindtap="popupShow" class="action" style="color:var(--glass-text-color);">我不</button>
      <button bindtap="ok" class="action" openType="share" style="color:var(--glass-primary-color);">分享</button>
    </view>
  </view>
</view>
